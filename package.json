{
  "name": "dpflab-site",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply dpflab --local",
    "db:migrate:remote": "wrangler d1 migrations apply dpflab --remote",
    "db:seed:local": "wrangler d1 execute dpflab --local --file=./seed.sql",
    "db:seed:remote": "wrangler d1 execute dpflab --remote --file=./seed.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "@libsql/client": "^0.17.4",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "drizzle-kit": "^0.31.10",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tslib": "^2.6.2",
    "typescript": "^5.4.0",
    "vite": "^8.0.11",
    "vitest": "^4.1.6",
    "wrangler": "^4.103.0"
  },
  "overrides": {
    "cookie": "^0.7.0"
  },
  "dependencies": {
    "@inlang/paraglide-js": "^2.18.0",
    "@tailwindcss/vite": "^4.3.0",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "tailwindcss": "^4.3.0"
  }
}
