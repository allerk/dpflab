{
  "name": "dpflab-site",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/lib/db/seed.ts"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "drizzle-kit": "^0.31.10",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tslib": "^2.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.11",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "cookie": "^0.7.0"
  },
  "dependencies": {
    "@inlang/paraglide-js": "^2.18.0",
    "@libsql/client": "^0.17.3",
    "@tailwindcss/vite": "^4.3.0",
    "drizzle-orm": "^0.45.2",
    "tailwindcss": "^4.3.0"
  }
}
