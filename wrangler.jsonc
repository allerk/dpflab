{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dpflab",
  "compatibility_date": "2026-06-21",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".svelte-kit/cloudflare/_worker.js",
  // Serve only via the custom domain (which sits behind Cloudflare Access);
  // disabling workers.dev prevents bypassing Access through the *.workers.dev URL.
  // TEMP: true for first-deploy smoke test until the custom domain is attached.
  "workers_dev": true,
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    // Set real values in Фаза 6 (or via dashboard). Not secrets — the AUD tag
    // and team domain are safe to keep in config.
    "CF_ACCESS_TEAM_DOMAIN": "PLACEHOLDER_TEAM",
    "CF_ACCESS_AUD": "PLACEHOLDER_AUD"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "dpflab",
      "database_id": "1cf109a2-4efd-48a5-b614-547a99125201",
      "migrations_dir": "drizzle"
    }
  ],
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "dpflab-images"
    }
  ]
}
